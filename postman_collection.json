{
  "info": {
    "name": "Casflo Worker API (Gemini Hybrid Mode D)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/api/auth/register",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"full_name\":\"Test User\",\"email\":\"test@example.com\",\"password\":\"secret123\"}"
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/api/auth/login",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"test@example.com\",\"password\":\"secret123\"}"
        }
      }
    },
    {
      "name": "Create Book",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/api/books",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\":\"Keluarga\",\"module_type\":\"FAMILY\"}"
        }
      }
    },
    {
      "name": "Scan Receipt (Gemini)",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/api/scan",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"image\":\"data:image/jpeg;base64,....\",\"book_id\":\"{{book_id}}\",\"provider\":\"gemini\"}"
        }
      }
    },
    {
      "name": "Scan Receipt (ChatGPT)",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/api/scan",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"image\":\"data:image/jpeg;base64,....\",\"book_id\":\"{{book_id}}\",\"provider\":\"chatgpt\"}"
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://your-worker.workers.dev"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "book_id",
      "value": ""
    }
  ]
}